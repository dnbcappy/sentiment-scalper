# Copy this file to .env and fill in real values.
# .env is gitignored - never commit real credentials.

# NewsAPI - register free at https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# Sentiment model: vader (fast, default) or finbert (finance-tuned, ~440MB)
SENTIMENT_MODEL=vader

# Reddit API (optional — if missing, scraper skips Reddit and uses NewsAPI only).
# Register a "script" type app at https://reddit.com/prefs/apps to get these.
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=sentiment-scalper/1.0 by github.com/dnbcappy

# Optional override for the DB connection. Defaults to local SQLite next to the
# scripts. Set to a postgresql://... URI to use hosted Postgres (Supabase etc).
# DATABASE_URL=